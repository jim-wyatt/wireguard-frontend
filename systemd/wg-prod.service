[Unit]
Description=WireGuard frontend production stack
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/ubuntu/wg
ExecStart=/usr/local/bin/wg-prod-stack up
ExecStop=/usr/local/bin/wg-prod-stack down
TimeoutStartSec=180
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target