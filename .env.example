# Database Configuration
DATABASE_URL=sqlite:///./wireguard.db
# For PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/wireguard

# WireGuard Configuration
WG_INTERFACE=wg0
WG_SERVER_IP=10.0.0.1
WG_SERVER_PORT=443
WG_SERVER_PUBLIC_KEY=your_server_public_key_here
WG_SERVER_PRIVATE_KEY=your_server_private_key_here
WG_SERVER_ENDPOINT=your.domain.com:443

# Network Configuration
WG_NETWORK=10.0.0.0/24
WG_DNS=1.1.1.1,8.8.8.8

# API Configuration
API_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","https://your.domain.com"]

# Frontend Configuration
VITE_API_URL=/api

# Caddy Configuration
DOMAIN=your.domain.com
