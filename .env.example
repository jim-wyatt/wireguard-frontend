# Database Configuration
POSTGRES_USER=wireguard
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=wireguard
DATABASE_URL=postgresql://wireguard:change-this-postgres-password@127.0.0.1:5432/wireguard

# WireGuard Configuration
WG_INTERFACE=wg0
WG_SERVER_IP=10.0.0.1
WG_SERVER_PORT=443
WG_SERVER_PUBLIC_KEY=your_server_public_key_here
WG_SERVER_PRIVATE_KEY=your_server_private_key_here
WG_SERVER_ENDPOINT=your.domain.com:443

# Network Configuration
WG_NETWORK=10.0.0.0/24
WG_DNS=1.1.1.1,8.8.8.8
# Route peer-to-peer traffic across the WireGuard subnet.
# For full-tunnel clients instead, set: "0.0.0.0/0, ::/0"
WG_CLIENT_ALLOWED_IPS=10.0.0.0/24

# API Configuration
API_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
API_AUTH_TOKEN=your-api-auth-token-here-generate-with-openssl-rand-hex-32
# Optional: structured scoped tokens with optional expiry (ISO-8601 UTC)
# API_AUTH_TOKENS_JSON=[{"token":"writer-token","role":"writer"},{"token":"readonly-token","role":"public","expires_at":"2026-12-31T23:59:59Z"}]
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","https://your.domain.com"]

# Frontend Configuration
VITE_API_URL=/api

# Caddy Configuration
DOMAIN=your.domain.com

# Deployment mode
# false = low-memory core stack only
# true = include Falco/CrowdSec/Trivy/eBPF sidecars
ENABLE_SECURITY_SIDECARS=false
PARCA_REMOTE_STORE_ADDRESS=127.0.0.1:7070

# Optional external metrics exporters
NODE_EXPORTER_ENDPOINT_URL=http://127.0.0.1:9100/metrics
PODMAN_EXPORTER_ENDPOINT_URL=http://127.0.0.1:9882/metrics
POSTGRES_EXPORTER_ENDPOINT_URL=http://127.0.0.1:9187/metrics
PARCA_SERVER_ENDPOINT_URL=http://127.0.0.1:7070
EBPF_EXPORTER_ENDPOINT_URL=http://127.0.0.1:9435/metrics
FALCOSIDEKICK_ENDPOINT_URL=http://127.0.0.1:2801/metrics
CROWDSEC_ENDPOINT_URL=http://127.0.0.1:8080/health
TRIVY_SERVER_ENDPOINT_URL=http://127.0.0.1:4954/version
WAZUH_API_ENDPOINT_URL=
FLEET_API_ENDPOINT_URL=
OSQUERY_EXPORTER_ENDPOINT_URL=
