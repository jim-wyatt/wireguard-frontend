FROM docker.io/library/python:3.14.4-slim-trixie

WORKDIR /app

ARG GIT_COMMIT=unknown
ENV GIT_COMMIT=${GIT_COMMIT}

# Install runtime tools used by debug endpoints and WireGuard operations.
RUN apt-get update && \
    apt-get install -y --no-install-recommends wireguard-tools iproute2 btop procps && \
    rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application
COPY . .

# Create directory for WireGuard configs
RUN mkdir -p /etc/wireguard

# Run as non-root user (note: WireGuard operations require elevated privileges)
# For production, you'll need to run with appropriate capabilities

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
